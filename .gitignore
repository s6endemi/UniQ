# Wellster Pipeline — raw patient data (never commit)
wellster-pipeline/data/raw/

# Wellster Pipeline — generated outputs (regenerate with `python pipeline.py`)
wellster-pipeline/output/*
!wellster-pipeline/output/.gitkeep

# Wellster Pipeline — golden master fixtures (regenerate; manifest is tracked)
wellster-pipeline/tests/fixtures/golden/*
!wellster-pipeline/tests/fixtures/golden/GOLDEN_MASTER.md
!wellster-pipeline/tests/fixtures/golden/.gitkeep

# Pipeline run log
wellster-pipeline/pipeline_run.log

# Generated chat-eval reports (regenerate via tests/run_chat_eval.py)
wellster-pipeline/tests/eval_*.json
!wellster-pipeline/tests/chat_eval_cases.json

